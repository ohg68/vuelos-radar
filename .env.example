# Base de datos (Railway Postgres o Neon). Si falta, usa SQLite local.
DATABASE_URL=postgresql://user:pass@host/db

# Telegram (obligatorio para alertas)
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=123456789

# Travelpayouts (gratis: travelpayouts.com → Tools → API)
TRAVELPAYOUTS_TOKEN=

# X API v2 (opcional — requiere plan Basic para leer timelines)
X_BEARER_TOKEN=

# Para parsear tweets con Claude Haiku (opcional, solo si usas X)
ANTHROPIC_API_KEY=
